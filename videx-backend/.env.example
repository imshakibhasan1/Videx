# ============================================================
# VIDEX Backend — Environment Variables Template
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ============================================================

# --- App -------------------------------------------------------
APP_NAME=VIDEX
DEBUG=false
# Generate with: python -c "import secrets; print(secrets.token_hex(64))"
SECRET_KEY=REPLACE_WITH_64_CHAR_HEX_SECRET

# Comma-separated list of allowed frontend origins
ALLOWED_ORIGINS=http://localhost:3000,https://videx.app

# --- Database --------------------------------------------------
# Format: postgresql+asyncpg://user:password@host:port/dbname
DATABASE_URL=postgresql+asyncpg://videx_user:videx_pass@localhost:5432/videx_db

# --- Redis -----------------------------------------------------
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# --- Cloudinary ------------------------------------------------
# Get from: https://cloudinary.com/console
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# Upload constraints (enforced server-side)
CLOUDINARY_MAX_BYTES=52428800   # 50MB
CLOUDINARY_MAX_DURATION=15      # 15 seconds

# --- MiMo V2.5 AI Engine ---------------------------------------
# Get from: https://opencode.ai
MIMO_API_KEY=your_opencode_api_key
MIMO_API_URL=https://opencode.ai/zen/v1/chat/completions
MIMO_MODEL=mimo-v2.5
MIMO_MAX_TOKENS=2048
MIMO_TIMEOUT=120.0
MIMO_FPS=2

# --- JWT -------------------------------------------------------
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# --- Rate Limiting (Free Tier MVP) ----------------------------
RATE_LIMIT_UPLOADS_PER_HOUR=10
RATE_LIMIT_PROMPTS_PER_DAY=50
